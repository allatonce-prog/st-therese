rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is signed in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Safely get the user's profile data
    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: Get user's role
    function getRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? getUserProfile().role : 'none';
    }

    // Role Checks
    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }
    function isDoctor() {
      return isAuthenticated() && getRole() == 'doctor';
    }
    function isNurse() {
      return isAuthenticated() && getRole() == 'nurse';
    }
    function isRegistration() {
      return isAuthenticated() && getRole() == 'registration';
    }
    function isPharmacist() {
      return isAuthenticated() && getRole() == 'pharmacy';
    }
    function isLabTech() {
      return isAuthenticated() && getRole() == 'laboratory';
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // --- Patients Collection ---
    match /patients/{patientId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isDoctor() || isNurse() || isRegistration();
    }

    // --- Rooms Collection ---
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- Beds Collection ---
    match /beds/{bedId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isDoctor() || isNurse();
    }

    // --- Admissions Collection ---
    match /admissions/{admissionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isDoctor() || isNurse() || isRegistration();
    }

    // --- Vital Signs Collection ---
    match /vitalSigns/{vitalId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isDoctor() || isNurse();
    }

    // --- Lab Orders Collection ---
    match /labOrders/{orderId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isDoctor() || isLabTech();
    }

    // --- Pharmacy Items Collection ---
    match /pharmacyItems/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isPharmacist();
    }

    // --- Dispensed Medications Collection ---
    match /dispensedMedications/{dispensedId} {
      allow read, write: if isAuthenticated();
    }
  }
}
